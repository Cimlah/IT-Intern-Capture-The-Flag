#!/usr/bin/env bash
# Login shell for the `intern` user. SSH lands here; we hand off to the Ink TUI.
set -eu

if [ ! -t 0 ] || [ ! -t 1 ]; then
  echo "This CTF hub requires an interactive terminal."
  echo "Reconnect with:  ssh -t intern@<host> -p <port>"
  exit 1
fi

if [ -f /etc/ctf/motd ]; then
  cat /etc/ctf/motd
fi

NODE_BIN="$(command -v node || true)"
if [ -z "$NODE_BIN" ]; then
  for candidate in /usr/local/bin/node /usr/bin/node; do
    if [ -x "$candidate" ]; then NODE_BIN="$candidate"; break; fi
  done
fi
if [ -z "$NODE_BIN" ]; then
  echo "FATAL: node not found on PATH or in /usr/local/bin, /usr/bin" >&2
  exit 127
fi

exec "$NODE_BIN" /opt/ctf-hub/dist/index.js "$@"
